# 数据库配置 - 请修改密码
DATABASE_URL=mysql+pymysql://leadmine:CHANGE_ME@mysql:3306/leadmine

# Redis配置 - 请修改密码
REDIS_URL=redis://:CHANGE_ME@redis:6379

# Elasticsearch配置
ELASTICSEARCH_URL=http://elasticsearch:9200

# RSSHub配置
RSSHUB_URL=http://rsshub:1200

# JWT配置 - 必须设置强密钥
# 生成方法: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_STRONG_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 应用配置
APP_NAME=LeadMine
APP_VERSION=1.0.0
DEBUG=false

# 管理员密码 - 请修改
ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# CORS配置
CORS_ORIGINS=http://localhost:8501

# 爬虫配置
CRAWL_TIMEOUT=30
MAX_CONCURRENT_CRAWLS=5
